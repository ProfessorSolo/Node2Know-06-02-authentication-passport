<h1>Public Home Page</h1>

<% if (locals.user) { %>
  <h2>Welcome back, <%= user.name || user.email %>!</h2>
  <p><a href="/admin/logout">Log Out</a></p>
<% } else { %>
  <p>You are browsing as a guest.</p>
  <p>
    <a href="/admin/login">Log In</a> | 
    <a href="/admin/register">Register</a>
  </p>
<% } %>

